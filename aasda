local cloneref = cloneref or function(i: Instance) return i; end;

local Players: Players = cloneref(game:GetService("Players"));
local UIS: UserInputService = cloneref(game:GetService("UserInputService"));

local plr = Players.LocalPlayer;
local cam = workspace.CurrentCamera;

-- Team definitions
local prisonerTeams = {
    ["minimum security"] = true,
    ["medium security"]  = true,
    ["maximum security"] = true,
    ["escapee"]          = true,
    ["booking"]          = true,
}
local ignoredTeams = { ["menu"] = true }

-- Fixed isSameTeam function - returns true if SAME team (should NOT target)
local isSameTeam = function(player: Player): boolean
    -- Basic null checks
    if not player or not player.Team or not plr.Team then 
        return false 
    end
    
    local myTeamName = string.lower(plr.Team.Name)
    local theirTeamName = string.lower(player.Team.Name)
    
    -- Check if either team is ignored
    if ignoredTeams[myTeamName] or ignoredTeams[theirTeamName] then
        return false
    end
    
    -- Same team = true (should NOT target)
    if myTeamName == theirTeamName then
        return true
    end
    
    -- Check if I'm a prisoner
    local imPrisoner = prisonerTeams[myTeamName]
    -- Check if they're a prisoner
    local theyrePrisoner = prisonerTeams[theirTeamName]
    
    -- If both are prisoners OR both are cops, it's same team (should NOT target)
    if imPrisoner and theyrePrisoner then
        return true
    elseif not imPrisoner and not theyrePrisoner then
        return true
    end
    
    -- Different teams (prisoner vs cop) = false (should target)
    return false
end;

-- Simple wall check function
local function canSeePart(part: BasePart): boolean
    if not part or not part.Parent then
        return false
    end
    
    local char = plr.Character
    if not char then
        return false
    end
    
    local origin = cam.CFrame.Position
    local direction = (part.Position - origin).Unit
    local distance = (part.Position - origin).Magnitude
    
    -- Raycast from camera to the target part
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {char, plr.Character}
    raycastParams.IgnoreWater = true
    
    local result = workspace:Raycast(origin, direction * distance, raycastParams)
    
    -- If no hit, we can see the part directly
    if not result then
        return true
    end
    
    -- Check if the hit part is part of the target's character
    local targetChar = part:FindFirstAncestorWhichIsA("Model")
    if targetChar and result.Instance:IsDescendantOf(targetChar) then
        return true
    end
    
    -- Check if the hit part is close enough to the target part (for partial visibility)
    local hitDistance = (result.Position - part.Position).Magnitude
    if hitDistance < 2 then
        return true
    end
    
    return false
end

-- Main getTarget function
local getTarget = function(): BasePart?
    local bestPart = nil
    local bestDistance = 300 -- FOV radius
    local mousePos = UIS:GetMouseLocation()
    
    -- Safety check for camera
    if not cam then
        cam = workspace.CurrentCamera
        if not cam then return nil end
    end
    
    for _, player: Player in next, Players:GetPlayers() do
        -- Skip self
        if player == plr then continue end
        
        -- Safe team check - if same team, skip
        local success, sameTeam = pcall(isSameTeam, player)
        if not success or sameTeam then 
            continue 
        end
        
        -- Get character safely
        local char = player.Character
        if not char then 
            continue 
        end
        
        -- Check for ForceField
        local forceField = char:FindFirstChildWhichIsA("ForceField")
        if forceField then 
            continue 
        end
        
        -- Check humanoid health
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then 
            continue 
        end
        
        -- Get target part (prioritize Head, then HumanoidRootPart)
        local tPart: BasePart? = char:FindFirstChild("Head")
        if not tPart then
            tPart = char:FindFirstChild("HumanoidRootPart")
        end
        if not tPart then
            tPart = char.PrimaryPart
        end
        if not tPart then 
            continue 
        end
        
        -- Check if on screen
        local pos, onScreen = cam:WorldToViewportPoint(tPart.Position)
        if not onScreen then 
            continue 
        end
        
        -- Check visibility with wall check
        local visible = canSeePart(tPart)
        
        -- If head isn't visible, try body parts
        if not visible then
            -- Try HumanoidRootPart
            local rootPart = char:FindFirstChild("HumanoidRootPart")
            if rootPart and rootPart ~= tPart then
                visible = canSeePart(rootPart)
                if visible then
                    tPart = rootPart
                end
            end
        end
        
        if not visible then 
            continue 
        end
        
        -- Calculate distance to mouse
        local distance = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
        
        -- Update best target
        if distance < bestDistance then
            bestPart = tPart
            bestDistance = distance
        end
    end
    
    return bestPart
end;

return getTarget
